{
  "schemaVersion": 1,
  "rulesetVersion": "google-maps-en-2026.07.3",
  "minimumAppVersionCode": 1,
  "createdAt": "2026-07-12T00:00:00Z",
  "publisher": "PebbleNTN maintainers",
  "rules": [
    {
      "id": "google-maps-arrive-en",
      "enabled": true,
      "priority": 200,
      "packageNames": [
        "com.google.android.apps.maps"
      ],
      "locales": [
        "en"
      ],
      "comment": "Title only, and never the bare word 'arrive'. Google Maps puts the ETA in subText ('Arrive 23:51') on EVERY navigation notification, so matching combinedText here classified every turn as ARRIVE (real capture, 2026-07-13).",
      "conditions": [
        {
          "field": "title",
          "operator": "regex",
          "value": "(?i)\\b(arriving|arrived|destination)\\b"
        }
      ],
      "output": {
        "maneuver": {
          "type": "literal",
          "value": "ARRIVE"
        },
        "primaryText": {
          "type": "firstNonEmpty",
          "fields": [
            "title",
            "text"
          ]
        },
        "secondaryText": {
          "type": "regexCapture",
          "field": "subText",
          "pattern": "(?i)\\barrive\\s+(\\d{1,2}:\\d{2}(?:\\s*[AaPp][Mm])?)",
          "group": 1
        }
      }
    },
    {
